# Temporal Infrastructure — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ---------------------------------------------------------------------------
# External PostgreSQL connection (Metabase's Postgres instance on the WSL host)
# ---------------------------------------------------------------------------
# POSTGRES_HOST options:
#   - 'host-gateway'  : resolves to Docker host's bridge IP (recommended, requires extra_hosts in compose)
#   - '172.17.0.1'    : default Docker bridge gateway (use if host-gateway doesn't work)
#   - explicit IP     : the WSL2 host IP (run: hostname -I | awk '{print $1}')
POSTGRES_HOST=host-gateway
POSTGRES_PORT=5432
POSTGRES_USER=temporal
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
