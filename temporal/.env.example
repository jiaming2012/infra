# Temporal Infrastructure — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ---------------------------------------------------------------------------
# External PostgreSQL connection (Metabase's Postgres instance on the WSL host)
# ---------------------------------------------------------------------------
# POSTGRES_HOST options:
#   - 'host-gateway'  : resolves to Docker host's bridge IP (recommended, requires extra_hosts in compose)
#   - '172.17.0.1'    : default Docker bridge gateway (use if host-gateway doesn't work)
#   - explicit IP     : the WSL2 host IP (run: hostname -I | awk '{print $1}')
POSTGRES_HOST=host-gateway
POSTGRES_PORT=5432
POSTGRES_USER=temporal
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Temporal Broadcast Address
# ---------------------------------------------------------------------------
# LAN IP of the Windows host (TheRealJCole). Temporal advertises this address
# to workers for follow-up gRPC RPCs. Must be the host's LAN IP, not 0.0.0.0
# or a Docker container IP.
#
# Change this if the machine's LAN IP changes.
#
# For remote workers outside the LAN (e.g., Digital Ocean), they need the
# router's public IP or a Tailscale tunnel (v2 — see OPS-01, OPS-02).
TEMPORAL_BROADCAST_ADDRESS=192.168.8.164

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
# Admin password for Grafana Web UI (http://localhost:3000)
# Default: admin (change for any non-local access)
GRAFANA_ADMIN_PASSWORD=admin
