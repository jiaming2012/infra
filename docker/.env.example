# Copy to .env and fill in real values. NEVER commit .env to git.

POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=trading

# Hetzner Object Storage (S3-compatible) — for WAL archiving
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=trading-wal-backups

# Exchange API keys (per bot — override in docker-compose or per-service env)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
